# =========================================================
# PORTFOLIO INTELLIGENCE PLATFORM
# ENVIRONMENT TEMPLATE
# =========================================================

# ---------------------------------------------------------
# NODE ENVIRONMENT
# ---------------------------------------------------------

NODE_ENV=development

# ---------------------------------------------------------
# PORTFOLIO API
# ---------------------------------------------------------

PORTFOLIO_API_PORT=4000

PORTFOLIO_API_HOST=localhost

PORTFOLIO_MONGO_URI=mongodb://localhost:27017/portfolio-intelligence

PORTFOLIO_LOG_LEVEL=info

# ---------------------------------------------------------
# FRONTEND
# ---------------------------------------------------------

VITE_API_BASE_URL=http://localhost:4000/api

# ---------------------------------------------------------
# EXTRACTOR
# ---------------------------------------------------------

EXTRACTOR_PROJECTS_PATH=./data/source-projects

EXTRACTOR_OUTPUT_PATH=./data/projects

EXTRACTOR_LOG_LEVEL=info

# ---------------------------------------------------------
# TELEMETRY
# ---------------------------------------------------------

ENABLE_TELEMETRY=true

ENABLE_EXTRACTION_DIAGNOSTICS=true

# ---------------------------------------------------------
# OBSERVABILITY
# ---------------------------------------------------------

CORRELATION_ID_HEADER=x-correlation-id

# ---------------------------------------------------------
# FEATURE FLAGS
# ---------------------------------------------------------

ENABLE_TOPOLOGY_VISUALIZATION=true

ENABLE_SCENARIO_ANALYTICS=true